print("Exercício 7-Verificar se um número é primo")
print("Desenvolva um programa que verifique se um número é primo. ")


num=(int(input("Informe o número para sabermos se e primo:")))

if num>1:
    for i in range (2,num):
        if (num%i==0):
            print("Não é primo")
            break
    else:
        print(f"O número {num} é primo!")
else:print(f"{num} Não é primo")
