print("Exercício 10- Números perfeitos ")
print("Desenvolva um programa que encontre todos os números perfeitos até 1000.")

#Percorre todos os números de 1 até 1000

for num in range(1,1001):
    #variavel que soma divisores
    soma_divisores=0
    #Verifica os possiveis divisores
    for i in range(1,num):
        #se i é divisor de num
        if num%i==0:
            soma_divisores+=i #soma o divisor
    if soma_divisores==num:
        print(f"{num} é perfeito!")
